# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/

# setuptools-scm — version derived from git tags at build time, written to
# constellation/_version.py. Source-tarball / wheel installs ship this file
# baked in; in-tree it stays generated state.
constellation/_version.py

# Virtualenvs / conda
.venv/
.env
.envrc

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# pytest / coverage / ruff
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# mkdocs
site/

# Jupyter
.ipynb_checkpoints/

# Third-party installs (fetched by scripts/install-*.sh; never commit binaries)
third_party/**
!third_party/README.md

# Viz frontend build artifacts. Source under constellation/viz/frontend/ is
# committed; the built bundle under constellation/viz/static/ is produced by
# `python -m constellation.viz.frontend.build` (or CI on tag push) and shipped
# in release wheels.
constellation/viz/static/**
!constellation/viz/static/.gitkeep
constellation/viz/frontend/node_modules/
constellation/viz/frontend/dist/
constellation/viz/frontend/.vite/
